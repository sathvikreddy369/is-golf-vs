PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
# Production: https://is-golf-vs.vercel.app or your custom domain
# Development: http://localhost:3000

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MONTHLY_ID=
RAZORPAY_PLAN_YEARLY_ID=
RAZORPAY_PLAN_MONTHLY_AMOUNT_CENTS=100000
RAZORPAY_PLAN_YEARLY_AMOUNT_CENTS=1000000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: secure internal backend-only endpoints called by server actions.
BACKEND_INTERNAL_API_SECRET=
CRON_SECRET=

# Optional: email notifications (subscription updates, draw results, winner alerts).
RESEND_API_KEY=
EMAIL_FROM=

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres"
# ===== FOR PRODUCTION DEPLOYMENT =====
# Backend: https://is-golf-vs.onrender.com
# Frontend: https://is-golf-vs.vercel.app

# FRONTEND_ORIGIN should match your frontend domain
# For production, set to: https://is-golf-vs.vercel.app

# BACKEND_INTERNAL_API_SECRET: Generate a secure random string
# Command: openssl rand -base64 32

# CRON_SECRET: Generate a secure random string for monthly draw cron job
# Command: openssl rand -base64 32
